# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
!frontend/lib/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment variables (secrets — never commit)
.env
.env.local
.env.*.local
# .env.example is committed as a template

# Logs
*.log
logs/

# Output files (use output/ directory instead)
output/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Node.js (if frontend added later)
node_modules/
.next/
npm-debug.log*

# Database
*.db
*.sqlite3

# Screenshots / uploads (large files)
uploads/
screenshots/

# Database backups (real journal data — must not be committed)
backups/

# Playwright test artifacts
frontend/test-results/

# Claude Code / AI-tool local artifacts (per-developer state, never tracked)
.claude/
.cursor/
.aider*
