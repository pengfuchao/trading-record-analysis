# ── Required ─────────────────────────────────────────────────────────────────
# Full Docker stack: DATABASE_URL is overridden by docker-compose.yml — the value
# here is only used by the local Windows backend (e.g. for MT5 live sync).
#
# For the local backend connecting to the Docker Postgres container use:
DATABASE_URL=postgresql+psycopg2://trading:trading@localhost:5432/trading_journal
#
# For a separate local Postgres install, replace with your own credentials:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/trading_journal

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Docker mode: docker-compose.yml defaults to http://localhost:3000 if this is not set.
# Local Mode 2 (Windows backend): this value is read directly by the backend.
# For remote deploys, set to your public frontend URL, e.g.: https://journal.example.com
CORS_ORIGINS=http://localhost:3000

# ── AI Coaching ──────────────────────────────────────────────────────────────
# Optional — coaching falls back to rule-based analysis without this.
# ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram Notifications ───────────────────────────────────────────────────
# Optional — push alerts for MT5 sync, FTMO status changes, coaching reviews.
# TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-1001234567890
# TELEGRAM_ENABLED=false   # uncomment to silence without removing tokens

# ── MT5 Passwords ────────────────────────────────────────────────────────────
# One env var per MT5 account. Key format: MT5_<ACCOUNT_ID_UPPER_UNDERSCORED>_PASSWORD
# Replace dashes and dots with underscores in the account ID.
# Example for account "ftmo-p1":
# MT5_FTMO_P1_PASSWORD=yourpassword
# Example for account "ic.markets.01":
# MT5_IC_MARKETS_01_PASSWORD=yourpassword

# ── Logging ──────────────────────────────────────────────────────────────────
# Optional — set log verbosity. Default: INFO. Options: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
